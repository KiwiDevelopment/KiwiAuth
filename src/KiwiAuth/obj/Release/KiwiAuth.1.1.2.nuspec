    <readme>README.md</readme>
    <description>Lightweight auth starter for ASP.NET Core — JWT access tokens, refresh token rotation, Google OAuth, and ASP.NET Identity without the ceremony.</description>
    <tags>auth jwt aspnetcore identity oauth refresh-token authentication authorization</tags>
    <repository type="git" url="https://github.com/KiwiAuth/KiwiAuth" commit="0676f5d10932495339947aae058c38a7af1b83c7" />
