{
  "ConnectionStrings": {
    "Default": "Data Source=kiwiauth.db"
  },
  "AllowedOrigins": [
    "http://localhost:5173",
    "https://localhost:5173"
  ],
  "KiwiAuth": {
    "Jwt": {
      "Issuer": "KiwiAuth.Sample",
      "Audience": "KiwiAuth.Client",
      "AccessTokenMinutes": 15
    },
    "RefreshToken": {
      "DaysToLive": 7
    },
    "Google": {
      "ClientId": "",
      "ClientSecret": ""
    },
    "Frontend": {
      "GoogleSuccessRedirectUrl": "http://localhost:5173/auth/callback",
      "GoogleErrorRedirectUrl": "http://localhost:5173/auth/error"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
